# ==============================
# Render full-stack environment
# ==============================
# Comma-separated origins allowed to call FastAPI.
# For single-service Render deployment, set your own Render app URL.
ALLOWED_ORIGINS=https://your-app.onrender.com

# Optional frontend override (usually NOT needed in full Render deployment)
# Frontend uses same-origin /api by default in production.
# VITE_API_BASE_URL=https://your-app.onrender.com/api
