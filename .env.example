# ==============================
# Backend (Render) environment
# ==============================
# Comma-separated origins allowed to call FastAPI
# Add your production Vercel domain after deployment.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-project.vercel.app

# ==============================
# Frontend (Vercel) environment
# ==============================
# Set this in Vercel project env vars.
# Recommended: point directly to Render backend API.
VITE_API_BASE_URL=https://your-backend-service.onrender.com/api

# Optional fallback (if using Vercel experimentalServices routing):
# VITE_API_BASE_URL=/_/backend/api
